#!/bin/sh
################################################################################
# PX4 SITL Configuration for QuadTailsitter in X-Plane
################################################################################
#
# @name              QuadTailsitter X-Plane SITL
# @class             VTOL
# @type              VTOL Quad Tailsitter
# @maintainer        alireza787b <p30planets@gmail.com>
# @url               https://github.com/alireza787b/px4xplane/
#
# X-Plane model:     QuadTailsitter.acf
# Compatible Sim:    X-Plane 12
# Control:           Four fixed rotors, no aerodynamic control surfaces
#
# This is a hover, low-speed navigation, and first airspeed-gated transition
# configuration. It follows PX4's official quadtailsitter SITL pattern, then
# applies the px4xplane sensor-fusion lessons learned from Alia and Ehang.
# qtail11 confirmed that X-Plane's conventional IAS dataref is negative in
# tailsitter fixed-wing attitude while the px4xplane body-axis pitot projection
# on -Z matches true airspeed. This file therefore enables PX4 airspeed feedback
# for transition and TECS while keeping checks conservative for SITL.
#
# USAGE:
#   make px4_sitl_default xplane_qtailsitter
#
################################################################################

. ${R}etc/init.d/rc.vtol_defaults


################################################################################
# AIRFRAME AND CONTROL ALLOCATION
################################################################################

param set-default MAV_TYPE 20
param set-default CA_AIRFRAME 4
param set-default CA_METHOD 2
param set-default CA_FAILURE_MODE 0

# qtail1 showed that the previous geometry used the X-Plane coordinates
# directly. X-Plane aircraft coordinates use X=right, Y=up, Z=tail; Plane Maker
# ACF position values are in feet. PX4 control allocation needs body X=forward
# and body Y=right in meters. The conversion below is:
#   PX4_X = -XPLANE_Z * 0.3048
#   PX4_Y =  XPLANE_X * 0.3048
# It preserves the existing px4xplane channel order and PX4 quadtailsitter sign
# pattern.
#
# qtail14 showed the aircraft was still the old 5 lb model, not the intended
# 5 kg 6S quad tailsitter. The v3.4.37 ACF retargets mass, battery, motor RPM,
# and a small 5 degree mirrored motor cant. Keep CT/KM conservative for the
# first 5 kg hover test and use the cant axes below to match the ACF.
param set-default CA_ROTOR_COUNT 4

param set-default CA_ROTOR0_PX 0.22
param set-default CA_ROTOR0_PY 0.43
param set-default CA_ROTOR0_AX -0.078
param set-default CA_ROTOR0_AY 0.040
param set-default CA_ROTOR0_AZ -0.996
param set-default CA_ROTOR0_CT 2.0
param set-default CA_ROTOR0_KM 0.04

param set-default CA_ROTOR1_PX -0.22
param set-default CA_ROTOR1_PY -0.43
param set-default CA_ROTOR1_AX 0.078
param set-default CA_ROTOR1_AY -0.040
param set-default CA_ROTOR1_AZ -0.996
param set-default CA_ROTOR1_CT 2.0
param set-default CA_ROTOR1_KM 0.04

param set-default CA_ROTOR2_PX 0.22
param set-default CA_ROTOR2_PY -0.43
param set-default CA_ROTOR2_AX -0.078
param set-default CA_ROTOR2_AY -0.040
param set-default CA_ROTOR2_AZ -0.996
param set-default CA_ROTOR2_CT 2.0
param set-default CA_ROTOR2_KM -0.04

param set-default CA_ROTOR3_PX -0.22
param set-default CA_ROTOR3_PY 0.43
param set-default CA_ROTOR3_AX 0.078
param set-default CA_ROTOR3_AY 0.040
param set-default CA_ROTOR3_AZ -0.996
param set-default CA_ROTOR3_CT 2.0
param set-default CA_ROTOR3_KM -0.04

param set-default CA_SV_CS_COUNT 0

param set-default PWM_MAIN_FUNC1 101
